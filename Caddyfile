# ─────────────────────────────────────────────────────────
# NigeriaTransfer — Caddy Reverse Proxy Configuration
# Production: serves nigeriatransfer.com with auto-HTTPS
# ─────────────────────────────────────────────────────────

nigeriatransfer.com {
    # Rate limiting: 300 requests/minute per IP
    rate_limit {remote.ip} 300r/m

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Content-Security-Policy "default-src 'self'; script-src 'self' https://pagead2.googlesyndication.com https://analytics.nigeriatransfer.com https://www.biowise.cc 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.googleusercontent.com https://*.r2.cloudflarestorage.com; connect-src 'self' https://analytics.nigeriatransfer.com https://api.paystack.co https://www.biowise.cc; frame-src https://pagead2.googlesyndication.com; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests;"
    }

    # Static assets: long cache (Next.js hashed filenames)
    @static path /_next/static/* /favicon.ico /robots.txt /sitemap.xml
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Next.js static chunks: if the proxy misses (e.g. a stale client is
    # requesting a chunk hash that no longer exists on disk because a
    # deploy happened since page-load), return a plain 404 with a
    # JS-safe content type. Without this, the Next.js upstream would
    # return the HTML 404 page, the browser's strict MIME check would
    # block it, React would fail to hydrate, and the whole tab would
    # crash with "Minified React error #418/#423". Skew protection
    # (next.config `deploymentId`) will hard-refresh the client on its
    # next navigation, so this only needs to keep the page alive long
    # enough to get there.
    @nextChunks path /_next/static/chunks/*
    handle @nextChunks {
        reverse_proxy localhost:3000 {
            @missing status 404 400 500 502 503 504
            handle_response @missing {
                header Content-Type "application/javascript; charset=utf-8"
                header Cache-Control "no-store"
                respond "// chunk not found — client should reload" 404
            }
        }
    }

    # Wallpaper images: 24-hour cache
    @wallpapers path /wallpapers/*
    header @wallpapers Cache-Control "public, max-age=86400"

    # Compression
    encode gzip zstd

    # Large file uploads: increase timeouts and body size
    @uploads path /api/upload/file /api/upload/file/* /api/upload/files/*
    handle @uploads {
        request_body {
            max_size 50GB
        }
        reverse_proxy localhost:3000 {
            transport http {
                read_timeout 2h
                write_timeout 2h
            }
        }
    }

    # Reverse proxy to Next.js
    reverse_proxy localhost:3000 {
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# www redirect
www.nigeriatransfer.com {
    redir https://nigeriatransfer.com{uri} permanent
}
