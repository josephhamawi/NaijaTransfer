# ─────────────────────────────────────────────────────────
# NaijaTransfer — Caddy Reverse Proxy Configuration
# Production: serves naijatransfer.com with auto-HTTPS.
# Large file uploads (>100 MB) are routed to upload.naijatransfer.com,
# a DNS-only subdomain that bypasses Cloudflare's 100 MB body cap.
# ─────────────────────────────────────────────────────────

# Primary site is served as HTTP here because Cloudflare fronts it
# in Flexible SSL mode: browsers reach CF over HTTPS, CF reaches
# Caddy over HTTP. If we let Caddy auto-HTTPS this domain it would
# 308-redirect to HTTPS, and CF's HTTP→origin request would bounce.
http://naijatransfer.com {
    # Rate limiting handled at the Cloudflare edge — Caddy's
    # rate_limit directive requires the caddy-ratelimit plugin
    # which isn't compiled into the prod binary, and adding it
    # would break `caddy validate` in the deploy script.

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Content-Security-Policy "default-src 'self'; script-src 'self' https://pagead2.googlesyndication.com https://analytics.nigeriatransfer.com https://www.biowise.cc 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.googleusercontent.com https://*.r2.cloudflarestorage.com; connect-src 'self' https://upload.naijatransfer.com https://analytics.nigeriatransfer.com https://api.paystack.co https://www.biowise.cc; frame-src https://pagead2.googlesyndication.com; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests;"
    }

    # Static assets: long cache (Next.js hashed filenames)
    @static path /_next/static/* /favicon.ico /robots.txt /sitemap.xml
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Next.js static chunks: if the proxy misses (e.g. a stale client is
    # requesting a chunk hash that no longer exists on disk because a
    # deploy happened since page-load), return a plain 404 with a
    # JS-safe content type. Without this, the Next.js upstream would
    # return the HTML 404 page, the browser's strict MIME check would
    # block it, React would fail to hydrate, and the whole tab would
    # crash with "Minified React error #418/#423". Skew protection
    # (next.config `deploymentId`) will hard-refresh the client on its
    # next navigation, so this only needs to keep the page alive long
    # enough to get there.
    @nextChunks path /_next/static/chunks/*
    handle @nextChunks {
        reverse_proxy localhost:3000 {
            @missing status 404 400 500 502 503 504
            handle_response @missing {
                header Content-Type "application/javascript; charset=utf-8"
                header Cache-Control "no-store"
                respond "// chunk not found — client should reload" 404
            }
        }
    }

    # Wallpaper images: 24-hour cache
    @wallpapers path /wallpapers/*
    header @wallpapers Cache-Control "public, max-age=86400"

    # Compression
    encode gzip zstd

    # Legacy upload path — kept for clients loaded before the bypass
    # subdomain existed. Cloudflare still caps request bodies at 100 MB
    # here, so real >100 MB uploads MUST use upload.naijatransfer.com.
    @uploads path /api/upload/file /api/upload/file/* /api/upload/files/*
    handle @uploads {
        request_body {
            max_size 50GB
        }
        reverse_proxy localhost:3000 {
            transport http {
                read_timeout 2h
                write_timeout 2h
            }
        }
    }

    # Reverse proxy to Next.js
    reverse_proxy localhost:3000 {
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# ─────────────────────────────────────────────────────────
# Upload bypass subdomain
#
# This subdomain must be configured as DNS-only (grey cloud) in
# Cloudflare, pointing at the Hetzner IP. That makes file POSTs hit
# Caddy directly, bypassing Cloudflare's 100 MB request-body cap on
# the Free/Pro/Business plans. Caddy auto-provisions a Let's Encrypt
# cert on first request once DNS resolves.
# ─────────────────────────────────────────────────────────
upload.naijatransfer.com {
    # CORS: the page is served from naijatransfer.com and XHRs land here
    # with custom headers (X-File-Name, X-File-Size) that trigger a
    # preflight — we answer it below.
    header Access-Control-Allow-Origin "https://naijatransfer.com"
    header Access-Control-Allow-Methods "POST, OPTIONS"
    header Access-Control-Allow-Headers "Content-Type, X-File-Name, X-File-Size"
    header Access-Control-Max-Age "86400"
    header Vary "Origin"

    @preflight method OPTIONS
    handle @preflight {
        respond 204
    }

    @upload path /api/upload/file /api/upload/file/*
    handle @upload {
        request_body {
            max_size 50GB
        }
        reverse_proxy localhost:3000 {
            header_up X-Forwarded-For {remote_host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-Proto {scheme}
            transport http {
                read_timeout 2h
                write_timeout 2h
            }
        }
    }

    # Upload-only subdomain — reject everything else.
    respond 404
}

# www redirect (also served as HTTP, proxied through Cloudflare)
http://www.naijatransfer.com {
    redir https://naijatransfer.com{uri} permanent
}
